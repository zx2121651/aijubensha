generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ------------------------------------------
// 用户体系 (User & Auth & Assets)
// ------------------------------------------
model User {
  id             String    @id @default(uuid())
  phone          String?   @unique
  email          String?   @unique
  passwordHash   String
  nickname       String
  avatar         String?
  role           Role      @default(PLAYER)
  status         UserStatus @default(NORMAL)

  // 钱包与资产
  coins          Float     @default(0)
  balance        Float     @default(0)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // 关系映射
  hostedRooms    Room[]    @relation("DmToRoom")
  playedRooms    RoomPlayer[]
  orders         Order[]
  posts          Post[]
  postComments   PostComment[]
  createdClubs   Club[]    @relation("ClubCreator")
  clubMemberships ClubMember[]
  editorProjects EditorProject[] @relation("ProjectCollaborators")
  ownedEditorProjects EditorProject[] @relation("ProjectOwner")
  friendshipsInitiated Friendship[] @relation("UserFriendInitiator")
  friendshipsReceived Friendship[] @relation("UserFriendReceiver")

  supportTickets SupportTicket[]
  coupons        Coupon[]
  dmSchedules    DmSchedule[]       @relation("DmScheduleRel")
  withdrawals    WithdrawalRequest[] @relation("UserWithdrawalRel")
}

enum Role {
  PLAYER
  DM
  AUTHOR
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  NORMAL
  BANNED
}

// 好友系统
model Friendship {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  status     FriendStatus @default(PENDING)
  createdAt  DateTime @default(now())

  sender     User     @relation("UserFriendInitiator", fields: [senderId], references: [id])
  receiver   User     @relation("UserFriendReceiver", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
}

enum FriendStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ------------------------------------------
// 剧本与资源体系 (Scripts & Resources)
// ------------------------------------------
model Script {
  id          String   @id @default(uuid())
  title       String
  cover       String?
  description String
  tags        String[]
  minPlayers  Int
  maxPlayers  Int
  difficulty  String
  duration    String
  status      ScriptStatus @default(DRAFT)
  price       Float    @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rooms       Room[]
  reviews     ScriptReview[]
  characters  Character[]
}

enum ScriptStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  OFFLINE
}

model Character {
  id          String   @id @default(uuid())
  scriptId    String
  name        String
  gender      String
  description String?
  avatar      String?

  script      Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)
}

model ScriptReview {
  id        String   @id @default(uuid())
  scriptId  String
  userId    String
  rating    Float
  content   String
  status    AuditStatus @default(APPROVED)
  createdAt DateTime @default(now())

  script    Script   @relation(fields: [scriptId], references: [id])
}

enum AuditStatus {
  PENDING
  APPROVED
  REJECTED
}

// ------------------------------------------
// 组局与游戏房间管控 (Room & Play)
// ------------------------------------------
model Room {
  id          String   @id @default(uuid())
  scriptId    String
  hostDmId    String?  // 可选，如果没有说明是无DM的自动场
  name        String
  isPrivate   Boolean  @default(false)
  password    String?
  phase       GamePhase @default(RECRUITING)

  createdAt   DateTime @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?

  script      Script   @relation(fields: [scriptId], references: [id])
  hostDm      User?    @relation("DmToRoom", fields: [hostDmId], references: [id])
  players     RoomPlayer[]
}

enum GamePhase {
  RECRUITING   // 招募中
  PREPARING    // 选角准备
  READING      // 读本中
  INVESTIGATING// 搜证中
  DISCUSSING   // 讨论中
  VOTING       // 投票结案
  REVEAL       // 复盘真相
  FINISHED     // 结束解散
}

model RoomPlayer {
  id          String   @id @default(uuid())
  roomId      String
  userId      String
  characterId String?
  isReady     Boolean  @default(false)
  isMuted     Boolean  @default(false)
  isDead      Boolean  @default(false) // 游戏中被杀或出局
  joinedAt    DateTime @default(now())

  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])
}

// ------------------------------------------
// 社区与公会 (Community & Clubs)
// ------------------------------------------
model Post {
  id          String   @id @default(uuid())
  authorId    String
  title       String
  content     String
  images      String[]
  status      AuditStatus @default(APPROVED)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User     @relation(fields: [authorId], references: [id])
  comments    PostComment[]
}

model PostComment {
  id        String   @id @default(uuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])
}

model Club {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  logo        String?
  creatorId   String
  createdAt   DateTime @default(now())

  creator     User     @relation("ClubCreator", fields: [creatorId], references: [id])
  members     ClubMember[]
}

model ClubMember {
  id        String   @id @default(uuid())
  clubId    String
  userId    String
  role      ClubRole @default(MEMBER)
  joinedAt  DateTime @default(now())

  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

enum ClubRole {
  MEMBER
  VICE_PRESIDENT
  PRESIDENT
}

// ------------------------------------------
// 财务与商城 (Finance & Orders)
// ------------------------------------------
model Order {
  id          String   @id @default(uuid())
  userId      String
  type        OrderType
  amount      Float
  status      OrderStatus @default(PENDING)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
}

enum OrderType {
  RECHARGE
  WITHDRAW
  SCRIPT_BUY
  ITEM_BUY
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

// ------------------------------------------
// 创作者平台 (Creator Editor)
// ------------------------------------------
model EditorProject {
  id          String   @id @default(uuid())
  ownerId     String
  name        String
  status      ScriptStatus @default(DRAFT)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner         User     @relation("ProjectOwner", fields: [ownerId], references: [id])
  collaborators User[]   @relation("ProjectCollaborators")

  characters    EditorCharacter[]
  acts          EditorAct[]
  investigations EditorInvestigation[]
  clues         EditorClue[]
  assets        EditorAsset[]
}

// ------------------------------------------
// 扩展：客服与反馈 (Support)
// ------------------------------------------
model SupportTicket {
  id          String   @id @default(uuid())
  userId      String
  type        String   // BUG, COMPLAINT, APPEAL
  content     String
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
}

model Faq {
  id          String   @id @default(uuid())
  question    String
  answer      String
  category    String
  orderIndex  Int      @default(0)
}

// ------------------------------------------
// 扩展：系统管理与营销 (System & Marketing)
// ------------------------------------------
model SystemNotice {
  id          String   @id @default(uuid())
  title       String
  content     String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Banner {
  id          String   @id @default(uuid())
  imageUrl    String
  linkUrl     String?
  position    String   // HOME, STORE, DISCOVER
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Coupon {
  id          String   @id @default(uuid())
  code        String   @unique
  discount    Float
  minAmount   Float    @default(0)
  validUntil  DateTime
  isUsed      Boolean  @default(false)
  userId      String?

  user        User?    @relation(fields: [userId], references: [id])
}

model StoreItem {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Float
  imageUrl    String?
  type        String   // AVATAR_FRAME, CHAT_BUBBLE, PROP
  isActive    Boolean  @default(true)
}

// ------------------------------------------
// 扩展：后台权限与系统日志 (RBAC & Logs)
// ------------------------------------------
model RoleConfig {
  id          String   @id @default(uuid())
  name        String   @unique
  permissions String[] // e.g. ["manage_users", "view_financials"]
  createdAt   DateTime @default(now())
}

model SystemLog {
  id          String   @id @default(uuid())
  adminId     String
  action      String
  details     String?
  ipAddress   String?
  createdAt   DateTime @default(now())
}

model SystemError {
  id          String   @id @default(uuid())
  message     String
  stackTrace  String?
  service     String
  createdAt   DateTime @default(now())
}

// ------------------------------------------
// 扩展：DM 专属业务 (DM Workbench)
// ------------------------------------------
model DmSchedule {
  id          String   @id @default(uuid())
  dmId        String
  startTime   DateTime
  endTime     DateTime
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime @default(now())

  dm          User     @relation("DmScheduleRel", fields: [dmId], references: [id])
}

model WithdrawalRequest {
  id          String   @id @default(uuid())
  userId      String
  amount      Float
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED, PAID
  method      String   // WECHAT, ALIPAY, BANK
  accountInfo String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation("UserWithdrawalRel", fields: [userId], references: [id])
}

// ------------------------------------------
// 扩展：创作者引擎 (Creator Platform details)
// ------------------------------------------
model EditorCharacter {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  gender      String
  avatar      String?
  background  String?
  createdAt   DateTime @default(now())

  project     EditorProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model EditorAct {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())

  project     EditorProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  nodes       EditorNode[]
}

model EditorNode {
  id          String   @id @default(uuid())
  actId       String
  type        String   // TEXT, CHOICE, EVENT
  content     String
  options     String?  // JSON stringified options
  nextNodes   String?  // JSON stringified connections

  act         EditorAct @relation(fields: [actId], references: [id], onDelete: Cascade)
}

model EditorInvestigation {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  mapUrl      String?

  project     EditorProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  targets     EditorSearchTarget[]
}

model EditorSearchTarget {
  id          String   @id @default(uuid())
  invId       String
  name        String
  xPosition   Float
  yPosition   Float

  investigation EditorInvestigation @relation(fields: [invId], references: [id], onDelete: Cascade)
}

model EditorClue {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  description String
  imageUrl    String?
  isPublic    Boolean  @default(false)

  project     EditorProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model EditorAsset {
  id          String   @id @default(uuid())
  projectId   String
  type        String   // IMAGE, AUDIO, VIDEO
  url         String
  size        Int      @default(0)

  project     EditorProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
